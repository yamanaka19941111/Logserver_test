###########################
# ベースイメージのインストール
###########################
FROM ubuntu:24.04

#################################################
# RUN命令でコンテナ内に必要エージェントをインストール
#################################################
# sender側にもrsyslogをインストールする
# sender/ホスト側にはrsyslogのインストールは不要？
RUN apt-get update && \
    apt-get install -y -q rsyslog && \
    apt-get install -y bsdutils

#############
# bash起動する
#############
CMD ["bash"]